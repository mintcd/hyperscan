digraph NFA {
rankdir=LR;
size="11.5,8"
node [ shape = circle ];
START [style=invis];
STARTF [style=invis];
STARTA [style=invis];
0 [style=invis];
1 [ width = 1, fixedsize = true, fontsize = 12, label = "1" ]; 
STARTA -> 1 [color = blue ]
1 -> 2 [ label = "[^\\nab]" ];
1 -> 1 [ label = "[\\na]" ];
1 -> 3 [ label = "b" ];
2 [ width = 1, fixedsize = true, fontsize = 12, label = "2" ]; 
2 [ color = darkgreen style=diagonals ];
STARTF -> 2 [color = red ]
2 -> 2 [ label = "[^\\n]" ];
2 -> 1 [ label = "\\n" ];
3 [ width = 1, fixedsize = true, fontsize = 12, label = "3" ]; 
3 [ shape = doublecircle ];
3 -> 2 [ label = "[^\\n]" ];
3 -> 1 [ label = "\\n" ];
}
